{
  "name": "@duo121/termhub",
  "version": "0.6.3",
  "description": "AI-native CLI for inspecting and controlling terminal tabs on macOS and Windows",
  "type": "module",
  "exports": {
    ".": "./src/sdk/index.js",
    "./sdk": "./src/sdk/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "termhub": "src/cli.js",
    "thub": "src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "README.zh-CN.md"
  ],
  "keywords": [
    "ai",
    "applescript",
    "cli",
    "cmd",
    "iterm2",
    "macos",
    "powershell",
    "windows",
    "windows-terminal",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duo121/termhub.git"
  },
  "homepage": "https://github.com/duo121/termhub#readme",
  "bugs": {
    "url": "https://github.com/duo121/termhub/issues"
  },
  "scripts": {
    "test": "node --test",
    "list": "node ./src/cli.js list",
    "doctor": "node ./src/cli.js doctor",
    "build:binary:host": "npx -y @yao-pkg/pkg@6.14.1 . --targets host --output dist/termhub",
    "pack:check": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "win32"
  ],
  "publishConfig": {
    "access": "public"
  }
}
