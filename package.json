{
  "name": "@duo121/termhub",
  "version": "0.2.0",
  "description": "AI-native CLI for inspecting and controlling macOS terminal tabs via AppleScript",
  "type": "module",
  "bin": {
    "termhub": "src/cli.js",
    "thub": "src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "README.zh-CN.md"
  ],
  "keywords": [
    "ai",
    "applescript",
    "cli",
    "iterm2",
    "macos",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duo121/termhub.git"
  },
  "homepage": "https://github.com/duo121/termhub#readme",
  "bugs": {
    "url": "https://github.com/duo121/termhub/issues"
  },
  "scripts": {
    "test": "node --test",
    "list": "node ./src/cli.js list",
    "doctor": "node ./src/cli.js doctor",
    "pack:check": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin"
  ],
  "publishConfig": {
